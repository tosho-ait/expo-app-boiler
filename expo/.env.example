# =========================================================================
# Expo mobile app — runtime environment (EXAMPLE)
# =========================================================================
# Copy this file to `.env` and fill in your own values.

# --- App identifiers ---
# These are read by expo/app.config.js to build app.json at runtime.
EXPO_APP_NAME=AppBoiler
EXPO_APP_SLUG=appboiler
EXPO_APP_SCHEME=appboiler
EXPO_IOS_BUNDLE_ID=com.example.appboiler
EXPO_ANDROID_PACKAGE=com.example.appboiler
EXPO_EAS_PROJECT_ID=
EXPO_OWNER=

# --- Backend API ---
# URL of your running web server (Next.js). Use http://<lan-ip>:3000 for local dev.
EXPO_PUBLIC_API_URL=http://localhost:3000

# --- Authentication (Clerk) ---
# Required. Clerk's "keyless mode" is Next.js-only — the Expo SDK always needs
# a publishable key. Easiest path: boot the web app with keyless mode, click
# "Configure your application", claim the instance, then copy the pk_test_*
# key from the Clerk dashboard here.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# --- Subscriptions (RevenueCat) ---
# Get from https://app.revenuecat.com. RC_ENTITLEMENT is the entitlement
# identifier you created in RC; RC_YEARLY_PRODUCT_ID is a product identifier
# inside a RC Offering (e.g. "com.example.app.pro.yearly").
EXPO_PUBLIC_RC_APPLE_KEY=
EXPO_PUBLIC_RC_GOOGLE_KEY=
EXPO_PUBLIC_RC_ENTITLEMENT=pro
EXPO_PUBLIC_RC_YEARLY_PRODUCT_ID=

# --- Dev flags ---
# When "true", the app behaves as if the user has an active Pro subscription.
EXPO_PUBLIC_PRO_FOR_TESTING=false
