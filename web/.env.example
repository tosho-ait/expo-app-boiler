# =========================================================================
# Web backend (Next.js) — runtime environment (EXAMPLE)
# =========================================================================
# Copy this file to `.env` and fill in your own values.

# --- Authentication (Clerk) ---
# KEYLESS MODE: leave both keys blank in development and Clerk will auto-provision
# a temporary dev instance. A "Configure your application" prompt appears in the
# UI — click it to claim the instance for free and get real keys.
# https://clerk.com/docs/quickstarts/nextjs
#
# For production you need real keys from https://dashboard.clerk.com.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# --- Database ---
# MongoDB connection string (include username/password and database name).
MONGODB_URI=

# --- Admin ---
# Email address allowed to access /analytics in production.
# In development mode (NODE_ENV=development) the check is skipped.
ADMIN_EMAIL=

# --- Analytics (optional) ---
# Google Analytics Measurement ID. Leave blank to disable the GA snippet.
NEXT_PUBLIC_GA_ID=

# --- App Store (for the landing-page download button) ---
NEXT_PUBLIC_APP_STORE_URL=

# --- iOS universal links (served at /.well-known/apple-app-site-association) ---
# Match the values used by your Expo app:
#   APPLE_TEAM_ID must equal EXPO_OWNER's Apple Developer Team ID.
#   IOS_BUNDLE_ID must equal EXPO_IOS_BUNDLE_ID.
APPLE_TEAM_ID=
IOS_BUNDLE_ID=

# --- Let's Encrypt / deployment (used by web/deployment/compose.yml) ---
# Only needed when deploying via the Docker Compose setup in web/deployment/.
LE_EMAIL=
LE_DOMAIN=
